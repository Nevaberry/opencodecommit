{
  "name": "opencodecommit",
  "version": "1.4.0",
  "description": "AI-powered git commit message generator that delegates to terminal AI agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nevaberry/opencodecommit.git"
  },
  "bin": {
    "occ": "bin/occ",
    "opencodecommit": "bin/occ"
  },
  "files": [
    "bin",
    "scripts",
    "platforms",
    "index.js"
  ],
  "scripts": {
    "prepack": "node scripts/sync-readme.js materialize",
    "postpack": "node scripts/sync-readme.js relink",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "cli",
    "opencode",
    "claude",
    "codex"
  ],
  "engines": {
    "node": ">=18"
  }
}
