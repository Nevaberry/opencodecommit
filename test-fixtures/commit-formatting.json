    "expected": "feat(cli): Add dry run output"
  },
  {
    "name": "appends multiline description",
    "response": "feat(cli): Update output\n\n- add text mode\n- remove duplicate status line",
    "config": {
      "commitTemplate": "{{type}}({{scope}}): {{message}}",
      "useLowerCase": true,
      "useEmojis": false,
      "emojis": {}
    },
    "expectedParsed": {
      "type": "feat",
      "scope": "cli",
      "message": "Update output",
