    },
    "expected": "feat(cli): update output\n\n- add text mode\n- remove duplicate status line"
  },
  {
    "name": "uses custom emoji placeholder with scope",
    "response": "feat(api): add endpoint",
    "config": {
      "commitTemplate": "{{emoji}} {{type}}({{scope}}): {{message}}",
      "useLowerCase": true,
      "useEmojis": true,
