[
  {
    "name": "formats unscoped conventional response with scoped default template",
    "response": "feat: Add login flow",
    "config": {
      "commitTemplate": "{{type}}({{scope}}): {{message}}",
      "useLowerCase": true,
      "useEmojis": false,
      "emojis": {}
    },
    "expectedParsed": {
      "type": "feat",
      "message": "Add login flow"
    },
    "expected": "feat: add login flow"
  },
  {
    "name": "preserves scope in conventional response",
    "response": "fix(extension): Handle missing repository path",
    "config": {
      "commitTemplate": "{{type}}({{scope}}): {{message}}",
      "useLowerCase": true,
      "useEmojis": false,
      "emojis": {}
    },
    "expectedParsed": {
      "type": "fix",
      "scope": "extension",
      "message": "Handle missing repository path"
    },
    "expected": "fix(extension): handle missing repository path"
  },
  {
    "name": "preserves model scope with legacy template",
    "response": "fix(auth): handle expired token",
    "config": {
      "commitTemplate": "{{type}}: {{message}}",
      "useLowerCase": true,
      "useEmojis": false,
      "emojis": {}
    },
    "expectedParsed": {
      "type": "fix",
      "scope": "auth",
      "message": "handle expired token"
    },
    "expected": "fix(auth): handle expired token"
  },
  {
    "name": "preserves case when lowercase is disabled",
    "response": "feat(cli): Add dry run output",
